#!/bin/sh
# Auto-update deployment timestamp in all HTML files before each commit.
# Format: <!-- deployed: YYYY-MM-DD HH:MM:SS -->

TIMESTAMP=$(date +"%Y-%m-%d %H:%M:%S")

update_file() {
    file="$1"
    [ -f "$file" ] || return 0

    if grep -q "<!-- deployed:.*-->" "$file"; then
        if sed --version >/dev/null 2>&1; then
            sed -i "s/<!-- deployed:.*-->/<!-- deployed: $TIMESTAMP -->/" "$file"
        else
            sed -i '' "s/<!-- deployed:.*-->/<!-- deployed: $TIMESTAMP -->/" "$file"
        fi
    else
        # Insert timestamp comment on the line after <!DOCTYPE html>
        if sed --version >/dev/null 2>&1; then
            sed -i "/<!DOCTYPE html>/a\\
<!-- deployed: $TIMESTAMP -->" "$file"
        else
            sed -i '' "/<!DOCTYPE html>/a\\
<!-- deployed: $TIMESTAMP -->
" "$file"
        fi
    fi

    git add "$file"
}

for file in *.html; do
    update_file "$file"
done
